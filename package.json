		"@types/bcrypt": "^6.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/jsonwebtoken": "^9.0.10",
		"drizzle-kit": "^0.31.9",
		"svelte": "^5.53.12",
		"svelte-carousel": "^1.0.25",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
		"vite": "^8.0.0"
	},
	"pnpm": {
