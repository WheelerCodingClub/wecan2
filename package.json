{
	"name": "wecan2",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.6.5",
	"engines": {
		"node": "<26.x"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"sync": "svelte-kit sync",
